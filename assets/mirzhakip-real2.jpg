<div id="scrollup">
    <img alt="Прокрутить вверх" title="Прокрутить вверх" src="https://e-history.kz/media/images/up.png">
</div>

<script>
    jQuery(document).ready(function () {
        $('.text-page .text img:not(.no_zoomify)').zoomify();
        jQuery('#scrollup img').mouseover(function () {
            jQuery(this).animate({opacity: 0.65}, 100);
        }).mouseout(function () {
            jQuery(this).animate({opacity: 1}, 100);
        }).click(function () {
            $('html, body').animate({scrollTop: $("body").offset().top}, 500);
            return false;
        });

        jQuery(window).scroll(function () {
            if (jQuery(document).scrollTop() > 0) {
                jQuery('#scrollup').fadeIn('fast');
            } else {
                jQuery('#scrollup').fadeOut('fast');
            }
        });
    });
    //art
    (function ($, w) {
        var $container = $('.text-page .text > p');
        var $lang = 'kz';
        var $aImages = {
            ru: 'https://e-history.kz/media/eiru.png',
            kz: 'https://e-history.kz/media/eikz.png',
            en: 'https://e-history.kz/media/eien.png'
        };

        if ($aImages[$lang] === undefined) {
            console.info('Нет баннера для языка', $lang);
            return;
        }

        if ($container.length === 0) {
            console.info('Нет контейнера для вывода /0!');
            return;
        }
    })(jQuery, window);

    var width = $(".select_time").width();
    width = width + 15;
    $(".select_time").css("width", width);
</script>

<link rel="stylesheet" href="https://e-history.kz/media/js/2019/bxslider/jquery.bxslider.css">

<script>
    $(document).ready(function () {
        $('.publ-window__down').on('click', function () {
            $('.publ-window__wrapper').scrollTop($('.publ-window__wrapper').scrollTop() + 10);
        });

        $('.synyp__ul').bxSlider({
            mode: 'horizontal',
            auto: false,
            pager: false,
            controls: true,
            adaptiveHeight: false,
            responsive: false,
            speed: 500,
            infiniteLoop: false,
            minSlides: 4,
            maxSlides: 4,
            moveSlides: 1,
            slideWidth: 297,
            slideMargin: 10,
        });

        $('.banner-full__ul').bxSlider({
            mode: 'horizontal',
            auto: false,
            pager: false,
            controls: true,
            adaptiveHeight: false,
            responsive: false,
            speed: 500,
            infiniteLoop: false,
            minSlides: 1,
            maxSlides: 1,
            moveSlides: 1,
        });

        $('.banners-js').bxSlider({
            mode: 'fade',
            auto: true,
            pager: false,
            controls: false,
            adaptiveHeight: false,
            responsive: false,
            speed: 500,
            infiniteLoop: true
        });

        $('.project_all_slider').bxSlider({
            mode: 'horizontal',
            auto: false,
            pager: false,
            controls: true,
            adaptiveHeight: true,
            slideWidth: 297,
            slideMargin: 10,
            minSlides: 4,
            maxSlides: 4,
        });
    });
</script>

